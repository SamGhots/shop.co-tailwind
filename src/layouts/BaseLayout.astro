---
import "../styles/style.css";
import PromotionBar from "../components/PromotionBar.astro";
import Navbar from "../components/Navbar.astro";
import Header from "../components/Header.astro";
import NewArrivalProduct from "../components/NewArrivalProduct.astro";
import BrandCarousel from "../components/BrandCarousel.astro";
import TopSelling from "../components/topSelling.astro";
import DressStyle from "../components/DressStyle.astro";
import CustomerReviews from "../components/CustomerReviews.astro";
import Newsletter from "../components/Newsletter.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
    />
    <title>Base Layout</title>
  </head>
  <body>
    <PromotionBar />
    <Navbar />
    <Header />
    <BrandCarousel />
    <NewArrivalProduct />
    <TopSelling />
    <DressStyle />
    <CustomerReviews />
    <Newsletter />
  </body>
</html>

<script src="../js/screen-reloader.js"></script>
<script src="../js/ProductDisplay/view-toggle.js"></script>