---
import Container from "./Container.astro";
import Mail from "../img/icons/mail.svg";
---

<section class="translate-y-1/3">
  <Container>
    <div class="bg-[var(--my-color-accent)] p-4 rounded-3xl flex flex-col  
   lg:py-9 lg:px-16  lg:flex-row lg:items-center lg:justify-between">
      <p class="text-2xl lg:text-4xl font-bold text-white text-left">
        STAY UPTO DATE ABOUT <br class="hidden lg:block"> OUR LATEST OFFERS
      </p>
      <div class="flex flex-col gap-3 mt-4 w-full lg:max-w-sm lg:mt-0">
        <div
          class="flex items-center bg-white rounded-full px-4 transition-all duration-200 focus-within:ring-4 focus-within:ring-amber-200"
        >
          <Mail class="w-6 h-6 text-gray-400" />

          <input
            type="email"
            placeholder="Enter your email address"
            class="w-full py-3 px-2 focus:outline-none text-gray-700 bg-transparent"
          />
        </div>
        <button
          class="bg-white text-black px-4 py-2 rounded-full font-bold transition-all duration-200
         hover:bg-gray-100
         active:scale-95 active:bg-gray-200 cursor-pointer "
        >
          Subscribe to Newsletter
        </button>
      </div>
    </div>
  </Container>
</section>
