---
const { title, img, star, fullPrice, discountPercentage } = Astro.props;
// ฟังก์ชันสำหรับสร้าง HTML สัญลักษณ์ดาวตามค่าคะแนนที่รับเข้ามา
function getStarRating(rating: number) {
  // สร้างตัวแปร string เปล่าเพื่อเก็บสัญลักษณ์ดาว
  let stars = "";
  // คำนวณจำนวนดาวเต็มโดยปัดเศษลง (เช่น 4.5 จะได้ 4)
  const fullStars = Math.floor(rating);
  // ตรวจสอบว่ามีค่าเศษเหลือจากการหารหรือไม่ เพื่อเช็คว่ามีครึ่งดาว
  const hasHalfStar = rating % 1 !== 0;

  // เปลี่ยนจากอีโมจิ '⭐️' เป็นแท็ก img ที่อ้างอิงถึงไฟล์ SVG
  const fullStarSVG = `<img src="./src/img/icons/Star.svg" alt="Full Star" style="width: 20px; height: 20px;">`; // ปรับขนาดตามต้องการ
  // สมมติว่ามีไฟล์สำหรับครึ่งดาว
  const halfStarSVG = `<img src="./src/img/icons/HalfStar.svg" alt="Half Star" style="width: 20px; height: 20px;">`;
  // วนลูปตามจำนวนดาวเต็มที่คำนวณได้
  for (let i = 0; i < fullStars; i++) {
    // เพิ่มสัญลักษณ์ดาวเต็ม '⭐️' เข้าไปใน string
    stars += fullStarSVG;
  }
  // หากมีครึ่งดาว ให้เพิ่มสัญลักษณ์ดาวครึ่ง '🌗' เข้าไป
  if (hasHalfStar) {
    stars += halfStarSVG;
  }
  // ส่งค่า string ที่มีสัญลักษณ์ดาวทั้งหมดกลับไป
  return stars;
}
---

<li class="flex flex-col">
  <div class="h-36 min-[375px]:h-45 min-[426px]:h-[33vh]   md:h-60 lg:h-60 xl:h-70">
    <img class="w-full rounded-2xl h-36 min-[375px]:h-45 min-[426px]:h-[33vh]  lg:h-60 xl:h-70" src={img} alt={title} />
  </div>
  <h3
    class="mt-2 font-bold text-[clamp(1rem,2vw,1.25rem)] truncate"
    title={title}
  >
    {title}
  </h3>
  <p class="mt-2 flex gap-1">
    <span class="flex" set:html={getStarRating(star)} /><span>
      <span>{star}</span>/<span class="text-gray-500">5</span>
    </span>
  </p>
  <section>
    {
      discountPercentage > 0 ? (
        <div class="flex flex-col min-[375px]:flex-row mt-2 min-[375px]:gap-1.5 md:gap-3 ">
          {/* ราคาขาย */}
          <p class="text-[clamp(1.25rem,3vw,1.5rem)] font-bold">
            ${(fullPrice - fullPrice * (discountPercentage / 100)).toFixed(2)}
          </p>
          <div class="flex items-center gap-2">
            {/* ราคาเต็ม (ขีดฆ่า) */}
            <p class=" text-[clamp(1.2rem,3vw,1.5rem)] font-bold  text-gray-500 line-through">
              ${fullPrice}
            </p>
            {/* ส่วนลด */}
            <p class="bg-red-100 rounded-full  text-red-700 w-fit p-1 text-[clamp(0.625rem,3vw,0.75rem)]">
              -{discountPercentage}%
            </p>
          </div>
        </div>
      ) : (
        <p class="mt-2 text-[clamp(1.25rem,3vw,1.5rem)] font-bold ">${fullPrice}</p>
      )
    }
  </section>
</li>
